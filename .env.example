# openPoly environment — copy to .env (gitignored) and fill in.
# .env is intentionally gitignored to keep secrets local.

# --- Trading wallet (Polygon V2 — slice C / Slice E) -----------------------
# After Polymarket's 2026-04-28 V2 upgrade, trading goes through a
# DepositWallet contract (POLY_1271, EIP-1271 signature). Both fields are
# required to switch to live mode; paper mode reads neither.
#
# OPENPOLY_POLYMARKET_PK    — 0x-hex 64-char private key of the EOA SIGNER.
#                             This EOA is the "owner" of the DepositWallet
#                             on chain, not the address that holds funds.
#                             Resolved via `env:OPENPOLY_POLYMARKET_PK` ref
#                             in ~/.openpoly/runtime.json wallet config.
# OPENPOLY_POLYMARKET_FUNDER — 0x-hex 40-char address of the on-chain
#                              DepositWallet contract that holds pUSD +
#                              CTF positions. Set in runtime.json directly
#                              (it's an address, not a secret).
OPENPOLY_POLYMARKET_PK=
OPENPOLY_POLYMARKET_FUNDER=

# --- Polygon RPC (optional; default works for read paths) ------------------
# Used only when the system needs on-chain reads beyond CLOB (e.g. slice D
# reconciliation, future on-chain redemption). Order placement does NOT
# need RPC — it's pure CLOB HTTP. Note: polygon-rpc.com returns 401 for
# some operators; the publicnode mirror works reliably.
OPENPOLY_POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# --- News source (M3+) -----------------------------------------------------
# TradingNews WS auth token. Resolved via env: ref in canvas / secret store.
OPENPOLY_TRADINGNEWS_API_KEY=

# --- Boot behavior ---------------------------------------------------------
# Set to "0" to skip auto-starting the news + market sources on app
# startup (default: enabled). Useful on memory-constrained hosts where
# the embedding section's sentence-transformers model load (~500MB) is a
# concern — the system boots clean and you start sources manually via
# POST /api/news_source/start + POST /api/market_source/start when ready.
# OPENPOLY_AUTOSTART_SOURCES=0

# --- Test / isolation overrides --------------------------------------------
# Uncomment to relocate state files away from defaults (~/.openpoly/...).
# OPENPOLY_SECRET_STORE=
# OPENPOLY_RUNTIME_STATE=
# OPENPOLY_CANVAS_STORE=
